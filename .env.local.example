# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic AI
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001

# App URL (used for share links, email links, and fire-and-forget internal fetches)
NEXT_PUBLIC_SITE_URL=https://bizdoc-ai.com

# Admin (comma-separated emails with access to /admin)
ADMIN_EMAILS=

# Resend (email sending — sign up at resend.com, verify your sending domain)
RESEND_API_KEY=
RESEND_FROM=BizDoc AI <noreply@bizdoc-ai.com>

# WhatsApp floating button (optional — omit or leave empty to hide)
# Format: country code + number with no spaces, e.g. 8613800138000
NEXT_PUBLIC_WHATSAPP_PHONE=

# Vercel Cron secret — set in Vercel dashboard and here; protects /api/cron/* routes
CRON_SECRET=
